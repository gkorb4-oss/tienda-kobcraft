# Vercel Postgres (auto-filled by Vercel when you add Postgres storage)
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NO_SSL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# JWT Secret - generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this

# Admin credentials (used for first setup)
ADMIN_EMAIL=admin@kobcraft.com
ADMIN_PASSWORD=changeme123

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
